local function CreateNavButton(name, iconId, overrideSize)
    local BtnContainer = Instance.new("Frame", ButtonList)
    BtnContainer.Size = UDim2.new(0, 36, 0, 36)
    BtnContainer.BackgroundTransparency = 1
    Instance.new("UICorner", BtnContainer).CornerRadius = UDim.new(0, 8)
    
    local Stroke = Instance.new("UIStroke", BtnContainer)
    Stroke.Thickness = 1
    Stroke.Color = Color3.fromRGB(255, 255, 255)
    Stroke.Transparency = 1

    local Icon = Instance.new("ImageButton", BtnContainer)
    local size = overrideSize or 28 
    Icon.Size = UDim2.new(0, size, 0, size)
    Icon.Position = UDim2.new(0.5, -(size/2), 0.5, -(size/2))
    Icon.BackgroundTransparency = 1
    Icon.Image = iconId
    Icon.ImageColor3 = Color3.fromRGB(150, 151, 160)
    Icon.ScaleType = Enum.ScaleType.Fit
    
    TabButtons[name] = Icon

    Icon.MouseEnter:Connect(function()
        if TabButtons.Selected ~= Icon then
            TweenService:Create(Icon, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(220, 221, 230)}):Play()
        end
    end)
    Icon.MouseLeave:Connect(function()
        if TabButtons.Selected ~= Icon then
            TweenService:Create(Icon, TweenInfo.new(0.2), {ImageColor3 = Color3.fromRGB(150, 151, 160)}):Play()
        end
    end)
    return Icon
end

