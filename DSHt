local tracersActive = false
local TracerLines = {}

local function ClearTracers()
    for _, line in pairs(TracerLines) do line:Remove() end
    TracerLines = {}
end

RunService.RenderStepped:Connect(function()
    if tracersActive then
        local cam = workspace.CurrentCamera
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local vector, onScreen = cam:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                if onScreen then
                    if not TracerLines[p] then
                        local line = Drawing.new("Line")
                        line.Thickness = 2
                        line.Transparency = 1
                        TracerLines[p] = line
                    end
                    TracerLines[p].Color = CurrentTracerColor
                    TracerLines[p].From = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y)
                    TracerLines[p].To = Vector2.new(vector.X, vector.Y)
                    TracerLines[p].Visible = true
                else
                    if TracerLines[p] then TracerLines[p].Visible = false end
                end
            else
                if TracerLines[p] then TracerLines[p]:Remove(); TracerLines[p] = nil end
            end
        end
    else
