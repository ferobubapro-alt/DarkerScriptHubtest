local function ApplyWaveTheme(frame, color1, color2, strokeColor)
    frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255) 
    local gradient = Instance.new("UIGradient", frame)
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, color1), 
        ColorSequenceKeypoint.new(1, color2)
    })
    gradient.Rotation = 45

    local stroke = frame:FindFirstChildOfClass("UIStroke")
    if not stroke then stroke = Instance.new("UIStroke", frame) end
    stroke.Color = strokeColor
    stroke.Thickness = 1.2
    stroke.Transparency = 0.8
end

local function Apply3ColorGradient(frame, c1, c2, c3, strokeColor)
    frame.BackgroundColor3 = Color3.fromRGB(255, 255, 255) 
    local gradient = Instance.new("UIGradient", frame)
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, c1), 
        ColorSequenceKeypoint.new(0.5, c2),
        ColorSequenceKeypoint.new(1, c3)
    })
    gradient.Rotation = 0

    local stroke = frame:FindFirstChildOfClass("UIStroke")
    if not stroke and strokeColor then stroke = Instance.new("UIStroke", frame) end
    if stroke then
        stroke.Color = strokeColor
        stroke.Thickness = 1.2
        stroke.Transparency = 0.8
    end
end

