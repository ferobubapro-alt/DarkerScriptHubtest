    tracerActive = active
    if active then
        TracerPickerFrame.Visible = true
        UpdateTracers()
    else
        TracerPickerFrame.Visible = false
        for _, line in pairs(tracerLines) do
            line:Remove()
        end
        tracerLines = {}
    end
end

