local cachedTotalFriends = 0
task.spawn(function()
    pcall(function()
        local page = Players:GetFriendsAsync(LocalPlayer.UserId)
        local count = 0
        while true do
            count = count + #page:GetCurrentPage()
            if not page.IsFinished then page:AdvanceToNextPageAsync() else break end
        end
        cachedTotalFriends = count
    end)
end)

task.spawn(function()
    while task.wait(3) do
        pcall(function()
            local friends = LocalPlayer:GetFriendsOnline(200) or {}
            local onlineCount, gameCount = 0, 0
            for _, info in ipairs(friends) do
                if info.LocationType == 2 then gameCount = gameCount + 1 end
                if info.IsOnline then onlineCount = onlineCount + 1 end
            end
            local offlineCount = math.max(0, cachedTotalFriends - onlineCount)
            InServerFr.Text = tostring(gameCount) .. " " .. (CurrentLanguage == "TR" and "arkadaş" or "friends")
            OnlineFr.Text = tostring(onlineCount) .. " " .. (CurrentLanguage == "TR" and "Çevrimiçi" or "Online")
            OfflineFr.Text = tostring(offlineCount) .. " " .. (CurrentLanguage == "TR" and "Çevrimdışı" or "Offline")
            AllFr.Text = tostring(cachedTotalFriends) .. " " .. (CurrentLanguage == "TR" and "Toplam" or "Total")
        end)
    end
end)

task.spawn(function()
    while task.wait(0.5) do
        if not ScreenGui or not ScreenGui.Parent then break end
        pcall(function() PingLabel.Text = tostring(math.round(Stats.Network.ServerStatsItem["Data Ping"]:GetValue())) .. "ms" end)
        local e = os.time() - joinTime
        TimeLabel.Text = string.format("%02d:%02d:%02d", math.floor(e/3600), math.floor((e%3600)/60), e%60)
    end
end)
