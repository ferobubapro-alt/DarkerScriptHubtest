local function ShowNotification(title, text, duration)
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(1, 0, 0, 60)
    Frame.BackgroundColor3 = Color3.fromRGB(20, 21, 26)
    Frame.BackgroundTransparency = 0.15
    Frame.Parent = NotificationHolder
    Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 10)
    
    local Stroke = Instance.new("UIStroke", Frame)
    Stroke.Thickness = 1
    Stroke.Color = Color3.fromRGB(255, 255, 255)
    Stroke.Transparency = 0.9

    local TitleLbl = Instance.new("TextLabel", Frame)
    TitleLbl.Size = UDim2.new(1, -20, 0, 20)
    TitleLbl.Position = UDim2.new(0, 10, 0, 8)
    TitleLbl.BackgroundTransparency = 1
    TitleLbl.Text = title
    TitleLbl.TextColor3 = Color3.fromRGB(156, 179, 255)
    TitleLbl.Font = Enum.Font.GothamBold
    TitleLbl.TextSize = 12
    TitleLbl.TextXAlignment = Enum.TextXAlignment.Left

    local TextLbl = Instance.new("TextLabel", Frame)
    TextLbl.Size = UDim2.new(1, -20, 0, 25)
    TextLbl.Position = UDim2.new(0, 10, 0, 26)
    TextLbl.BackgroundTransparency = 1
    TextLbl.Text = text
    TextLbl.TextColor3 = Color3.fromRGB(200, 201, 210)
    TextLbl.Font = Enum.Font.GothamMedium
    TextLbl.TextSize = 10
    TextLbl.TextXAlignment = Enum.TextXAlignment.Left
    TextLbl.TextWrapped = true

    TweenService:Create(Frame, TweenInfo.new(0.3), {BackgroundTransparency = 0.15}):Play()
    task.delay(duration or 3, function()
        TweenService:Create(Frame, TweenInfo.new(0.3), {BackgroundTransparency = 1}):Play()
        TweenService:Create(Stroke, TweenInfo.new(0.3), {Transparency = 1}):Play()
        TweenService:Create(TitleLbl, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        TweenService:Create(TextLbl, TweenInfo.new(0.3), {TextTransparency = 1}):Play()
        task.wait(0.3)
        Frame:Destroy()
    end)
end

