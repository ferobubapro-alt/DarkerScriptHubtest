local isFlying = false; local flySpeed = 50; local flyBV, flyBG, flyLoop
local function StartFly()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    isFlying = true; char.Humanoid.PlatformStand = true
    local hrp = char.HumanoidRootPart
    flyBV = Instance.new("BodyVelocity", hrp); flyBV.MaxForce = Vector3.new(math.huge, math.huge, math.huge); flyBV.Velocity = Vector3.new(0,0,0)
    flyBG = Instance.new("BodyGyro", hrp); flyBG.MaxTorque = Vector3.new(math.huge, math.huge, math.huge); flyBG.P = 10000; flyBG.CFrame = workspace.CurrentCamera.CFrame
    flyLoop = RunService.RenderStepped:Connect(function()
        if not isFlying or not char.Parent then return end
        local cam = workspace.CurrentCamera; flyBG.CFrame = cam.CFrame
        local moveVec = Vector3.new(0,0,0)
        pcall(function() moveVec = require(LocalPlayer.PlayerScripts:WaitForChild("PlayerModule")):GetControls():GetMoveVector() end)
        local moveDir = (cam.CFrame.RightVector * moveVec.X) + (cam.CFrame.LookVector * -moveVec.Z)
        if moveDir.Magnitude > 0 then moveDir = moveDir.Unit end
        flyBV.Velocity = moveDir * flySpeed
    end)
    ShowNotification("Fly", Translates[CurrentLanguage].FlyActive, 3)
end
local function StopFly()
    isFlying = false
    if flyBV then flyBV:Destroy() end; if flyBG then flyBG:Destroy() end; if flyLoop then flyLoop:Disconnect() end
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then LocalPlayer.Character.Humanoid.PlatformStand = false end
    ShowNotification("Fly", Translates[CurrentLanguage].FlyDeactive, 2)
end
CreateModPanel(StarScroll, "Fly Hack", true, 500, 50, function(a) if a then StartFly() else StopFly() end end, function(v) flySpeed = v end)

